# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=telegram_seller

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_MINI_APP_URL=https://your-domain.com
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
# Секрет для проверки webhook (32+ символов). Генерируйте: openssl rand -hex 32
# Telegram отправляет его в заголовке X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-min-32-chars

# Session
SESSION_SECRET=your-session-secret-min-32-chars-change-in-production

# Cron (для защиты cron endpoints)
# Генерируйте через: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key-min-32-chars

# Environment
NODE_ENV=development

# Maintenance (опционально, для быстрого включения без доступа к БД)
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Система находится на техническом обслуживании. Пожалуйста, попробуйте позже.
