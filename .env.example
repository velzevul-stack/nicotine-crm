# Тестовый сид (npm run db:seed): ключ для пользователя telegramId=dev-user-1
# Не коммитьте реальный ключ; локально скопируйте из приложения или задайте свой.
DEV_SEED_ACCESS_KEY=KEY-your-access-key-here

# Опционально: сид вешает демо-данные на пользователя с этим telegramId (число из Telegram),
# если он уже есть в БД. Иначе сид ищет @wendigo2347 по username / фиксированному ключу, затем dev-user-1.
# SEED_OWNER_TELEGRAM_ID=123456789

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=telegram_seller

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_MINI_APP_URL=https://lyxbit.com
# Webhook (только если НЕ используете long polling / PM2 telegram-bot-polling):
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=openssl-rand-hex-32-min-chars

# Session (production: минимум 32 символа; лучше: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-min-32-chars-change-in-production

# Cron (для защиты cron endpoints)
# Генерируйте через: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key-min-32-chars

# Environment (на VPS: production)
NODE_ENV=development

# Maintenance (опционально, для быстрого включения без доступа к БД)
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Система находится на техническом обслуживании. Пожалуйста, попробуйте позже.
